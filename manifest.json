{
  "manifest_version": 3,
  "name": "Scryfall Search",
  "version": "1.0.0",
  "description": "Right-click a link or selected text to search it as a card name on Scryfall.",
  "browser_specific_settings": {
    "gecko": {
      "id": "scryfall-search@yourname.example",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["menus", "activeTab", "scripting"],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/scry-icon.svg",
    "32": "icons/scry-icon.svg",
    "48": "icons/scry-icon.svg",
    "96": "icons/scry-icon.svg"
  }
}
